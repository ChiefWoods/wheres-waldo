{
  "name": "server",
  "version": "1.0.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "main": "app.ts",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "dev": "fastify start --ignore-watch=.ts$ -w -l info -P src/app.ts",
    "start": "fastify start -l info -P src/app.ts",
    "test": "bun test",
    "lint": "oxlint --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint --fix --no-error-on-unmatched-pattern",
    "format": "oxfmt --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern",
    "fmt": "oxfmt --no-error-on-unmatched-pattern",
    "fmt:check": "oxfmt --check --no-error-on-unmatched-pattern",
    "db:migrate": "bunx --bun prisma migrate dev --name init",
    "db:generate": "bunx --bun prisma generate",
    "db:studio": "bunx --bun -p better-sqlite3 -p prisma prisma studio --url file:./data/dev.db"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/sensible": "^6.0.0",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "fastify-tsconfig": "^3.0.0",
    "lint-staged": "^17.0.3",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.4.0",
    "typescript": "~6.0.3"
  }
}
